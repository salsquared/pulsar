# Production environment — copy to .env.production and fill in values
# .env.production is gitignored; this file is committed as the template.

# SQLite DB path (relative to prisma/schema.prisma, so this lands at prisma/prod.db)
DATABASE_URL="file:./prod.db"

# Internal shared secret — generate with: openssl rand -hex 32
# Rotate by updating this value and running: pm2 reload "pulsar*"
PULSAR_INTERNAL_TOKEN=

# External API keys — production / paid keys go here
COINGECKO_API_KEY=
ALPHA_VANTAGE_KEY=
FRED_API_KEY=
EXCHANGERATE_API_KEY=

# Optional tuning
# TICK_RETENTION_DAYS=90
# WS_MAX_SUBSCRIPTIONS=500
# PORT=3103
