# Development environment — copy to .env.development and fill in values
# .env.development is gitignored; this file is committed as the template.

# SQLite DB path (relative to prisma/schema.prisma, so this lands at prisma/dev.db)
DATABASE_URL="file:./dev.db"

# Internal shared secret — generate with: openssl rand -hex 32
# Used by ingest jobs to call /internal/notify and by operators to call POST /ingest/:sourceId
PULSAR_INTERNAL_TOKEN=

# External API keys — dev keys / free-tier keys go here
COINGECKO_API_KEY=
ALPHA_VANTAGE_KEY=
FRED_API_KEY=
EXCHANGERATE_API_KEY=

# Optional tuning
# TICK_RETENTION_DAYS=90
# WS_MAX_SUBSCRIPTIONS=500
# PORT=4103
