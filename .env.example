# Pulsar environment — copy to .env and fill in values.
# .env is gitignored; this file is committed as the template.

# SQLite DB path (relative to prisma/schema.prisma, so this lands at prisma/pulsar.db)
DATABASE_URL="file:./pulsar.db"

# Internal shared secret — generate with: openssl rand -hex 32
# Rotate by updating this value and running: pm2 reload "pulsar*"
PULSAR_INTERNAL_TOKEN=

# External API keys
COINGECKO_API_KEY=
ALPHA_VANTAGE_KEY=
FRED_API_KEY=
EXCHANGERATE_API_KEY=

# Optional tuning
# TICK_RETENTION_DAYS=90
# WS_MAX_SUBSCRIPTIONS=500
# PORT=3103
